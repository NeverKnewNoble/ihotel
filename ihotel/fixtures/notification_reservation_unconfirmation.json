[
 {
  "doctype": "Notification",
  "name": "Reservation Unconfirmation Letter",
  "enabled": 1,
  "is_standard": 0,
  "channel": "Email",
  "document_type": "Reservation",
  "event": "New",
  "condition_type": "Python",
  "condition": "doc.status in ('pending', 'Pending') and not doc.unconfirmation_email_sent",
  "set_property_after_alert": "unconfirmation_email_sent",
  "property_value": "1",
  "subject": "Reservation Received (Pending Confirmation) — {{ doc.name }}",
  "message_type": "HTML",
  "send_system_notification": 0,
  "attach_print": 0,
  "recipients": [
   {
    "doctype": "Notification Recipient",
    "receiver_by_document_field": "email_address"
   }
  ],
  "message": "{% set s = frappe.get_doc('iHotel Settings', 'iHotel Settings') %}\n{% set hotel = s.hotel_name or 'iHotel' %}\n{% set currency = s.currency or '' %}\n{% set ci_time = (frappe.format_value(s.default_check_in_time, {\"fieldtype\": \"Time\"}) if s.default_check_in_time else '14:00:00')[:5] %}\n{% set co_time = (frappe.format_value(s.default_check_out_time, {\"fieldtype\": \"Time\"}) if s.default_check_out_time else '12:00:00')[:5] %}\n{% set signatory = s.hotel_signatory_name or ('The ' + hotel + ' Team') %}\n{% set sign_title = s.hotel_signatory_title or '' %}\n{% set pax = (doc.adults or 1)|string + ' Adult' + ('s' if (doc.adults or 1) != 1 else '') %}\n{% if doc.children %}{% set pax = pax + ' · ' + doc.children|string + ' Child' + ('ren' if doc.children != 1 else '') %}{% endif %}\n{% set room_pax = (doc.room_type or '-') + ' · ' + pax %}\n{% if doc.no_of_rooms and doc.no_of_rooms > 1 %}{% set room_pax = doc.no_of_rooms|string + '-' + room_pax %}{% endif %}\n{% set rate_label = doc.rate_type or '' %}\n{% if doc.rate_type %}\n  {% set rt = frappe.get_doc('Rate Type', doc.rate_type) %}\n  {% if rt.rate_type_name %}{% set rate_label = rt.rate_type_name %}{% endif %}\n{% endif %}\n{% set nightly_rate = (doc.rate_lines[0].amount if doc.rate_lines and doc.rate_lines[0].amount else (doc.rate_lines[0].rate if doc.rate_lines else 0)) %}\n{% set nightly_str = frappe.utils.fmt_money(nightly_rate or 0, currency=currency) %}\n{% set total_str = frappe.utils.fmt_money(doc.total_rental or 0, currency=currency) %}\n{% set payment = doc.payment_method or 'Not specified' %}\n{% if doc.credit_card_type %}{% set payment = doc.credit_card_type %}{% if doc.credit_card_last4 %}{% set payment = payment + ' •••• ' + doc.credit_card_last4 %}{% endif %}{% endif %}\n{% set arr_time = doc.eta or doc.check_in_time %}\n{% if arr_time %}{% set arr_time = (frappe.format_value(arr_time, {\"fieldtype\": \"Time\"}) or '')[:5] %}{% else %}{% set arr_time = 'To be advised' %}{% endif %}\n{% set prefs = doc.special_requests or '' %}\n{% set source = doc.business_source_category or '' %}\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta name=\"color-scheme\" content=\"light\">\n  <title>Reservation Received</title>\n</head>\n<body style=\"margin:0;padding:0;background:#f5f5f4;font-family:system-ui,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1c1917;\">\n\n  <!-- Preheader (hidden preview text) -->\n  <div style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;\">We've received your reservation. It's pending final confirmation.</div>\n\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#f5f5f4;padding:40px 16px;\">\n    <tr><td align=\"center\">\n\n      <table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:600px;width:100%;background:#ffffff;border-radius:14px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04),0 4px 20px rgba(0,0,0,.06);\">\n\n        <!-- Accent bar -->\n        <tr><td style=\"height:6px;background:#b45309;line-height:0;font-size:0;\">&nbsp;</td></tr>\n\n        <!-- Header -->\n        <tr><td style=\"padding:36px 40px 0 40px;\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n            <tr>\n              <td style=\"font-size:13px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:#b45309;\">{{ hotel }}</td>\n              <td align=\"right\" style=\"font-size:12px;color:#78716c;letter-spacing:.04em;\">\n                {{ frappe.utils.formatdate(frappe.utils.nowdate(), 'dd MMM yyyy')|upper }}\n              </td>\n            </tr>\n          </table>\n        </td></tr>\n\n        <!-- Title -->\n        <tr><td style=\"padding:20px 40px 8px 40px;\">\n          <h1 style=\"margin:0;font-size:28px;font-weight:700;line-height:1.2;letter-spacing:-0.02em;color:#1c1917;\">Reservation Received</h1>\n          <p style=\"margin:8px 0 0 0;font-size:15px;line-height:1.55;color:#57534e;\">Your booking is currently awaiting confirmation.</p>\n        </td></tr>\n\n        <!-- Status pill -->\n        <tr><td style=\"padding:20px 40px 0 40px;\">\n          <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n            <tr>\n              <td style=\"background:#fef3c7;border-radius:999px;padding:6px 14px 6px 12px;\">\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr>\n                  <td style=\"padding-right:8px;line-height:0;\"><span style=\"display:inline-block;width:8px;height:8px;border-radius:50%;background:#f59e0b;\"></span></td>\n                  <td style=\"font-size:12px;font-weight:600;letter-spacing:.04em;color:#78350f;text-transform:uppercase;\">Pending Confirmation</td>\n                </tr></table>\n              </td>\n              <td style=\"padding-left:10px;font-size:13px;color:#78716c;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;\">{{ doc.name }}</td>\n            </tr>\n          </table>\n        </td></tr>\n\n        <!-- Greeting & intro -->\n        <tr><td style=\"padding:28px 40px 0 40px;\">\n          <p style=\"margin:0 0 12px 0;font-size:15px;line-height:1.55;color:#1c1917;\">Dear <strong>{{ doc.full_name or 'Guest' }}</strong>,</p>\n          <p style=\"margin:0;font-size:14px;line-height:1.65;color:#44403c;\">Thank you for your reservation request at {{ hotel }}. We have received your booking. It is currently <strong>pending confirmation</strong> — you will receive a separate Confirmation Letter once your stay is confirmed.</p>\n        </td></tr>\n\n        <!-- Stay summary card -->\n        <tr><td style=\"padding:28px 40px 0 40px;\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#fafaf9;border:1px solid #e7e5e4;border-radius:10px;\">\n            <tr>\n              <td width=\"50%\" style=\"padding:18px 20px;border-right:1px solid #e7e5e4;\">\n                <div style=\"font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#78716c;margin-bottom:6px;\">Arrival</div>\n                <div style=\"font-size:18px;font-weight:600;color:#1c1917;letter-spacing:-0.01em;\">\n                  {{ frappe.utils.formatdate(doc.check_in_date, 'EEE, dd MMM yyyy') if doc.check_in_date else '—' }}\n                </div>\n                <div style=\"font-size:13px;color:#57534e;margin-top:4px;\">From <strong>{{ ci_time }}</strong> • ETA {{ arr_time }}</div>\n              </td>\n              <td width=\"50%\" style=\"padding:18px 20px;\">\n                <div style=\"font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#78716c;margin-bottom:6px;\">Departure</div>\n                <div style=\"font-size:18px;font-weight:600;color:#1c1917;letter-spacing:-0.01em;\">\n                  {{ frappe.utils.formatdate(doc.check_out_date, 'EEE, dd MMM yyyy') if doc.check_out_date else '—' }}\n                </div>\n                <div style=\"font-size:13px;color:#57534e;margin-top:4px;\">By <strong>{{ co_time }}</strong> • {{ doc.days or 0 }} night(s)</div>\n              </td>\n            </tr>\n          </table>\n        </td></tr>\n\n        <!-- Reservation details -->\n        <tr><td style=\"padding:24px 40px 0 40px;\">\n          <div style=\"font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#78716c;margin-bottom:12px;\">Reservation Details</div>\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"border-collapse:collapse;\">\n            <tr>\n              <td style=\"padding:10px 0;border-bottom:1px solid #f5f5f4;font-size:13px;color:#78716c;width:42%;\">Guest</td>\n              <td style=\"padding:10px 0;border-bottom:1px solid #f5f5f4;font-size:14px;color:#1c1917;font-weight:500;\">{{ doc.full_name or '—' }}</td>\n            </tr>\n            <tr>\n              <td style=\"padding:10px 0;border-bottom:1px solid #f5f5f4;font-size:13px;color:#78716c;\">Room type · Occupancy</td>\n              <td style=\"padding:10px 0;border-bottom:1px solid #f5f5f4;font-size:14px;color:#1c1917;font-weight:500;\">{{ room_pax }}</td>\n            </tr>\n            {% if source %}\n            <tr>\n              <td style=\"padding:10px 0;border-bottom:1px solid #f5f5f4;font-size:13px;color:#78716c;\">Booking source</td>\n              <td style=\"padding:10px 0;border-bottom:1px solid #f5f5f4;font-size:14px;color:#1c1917;font-weight:500;\">{{ source }}</td>\n            </tr>\n            {% endif %}\n            <tr>\n              <td style=\"padding:10px 0;border-bottom:1px solid #f5f5f4;font-size:13px;color:#78716c;\">Payment method</td>\n              <td style=\"padding:10px 0;border-bottom:1px solid #f5f5f4;font-size:14px;color:#1c1917;font-weight:500;\">{{ payment }}</td>\n            </tr>\n            {% if prefs %}\n            <tr>\n              <td style=\"padding:10px 0;font-size:13px;color:#78716c;vertical-align:top;\">Preferences</td>\n              <td style=\"padding:10px 0;font-size:14px;color:#1c1917;line-height:1.5;\">{{ prefs }}</td>\n            </tr>\n            {% endif %}\n          </table>\n        </td></tr>\n\n        <!-- Rate / total block -->\n        <tr><td style=\"padding:24px 40px 0 40px;\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#1c1917;border-radius:10px;\">\n            <tr>\n              <td style=\"padding:22px 24px;\">\n                <div style=\"font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#a8a29e;margin-bottom:4px;\">Room rate</div>\n                <div style=\"font-size:22px;font-weight:700;color:#ffffff;letter-spacing:-0.02em;\">{{ nightly_str }} <span style=\"font-size:13px;font-weight:400;color:#a8a29e;\">/ night</span></div>\n                {% if rate_label %}<div style=\"font-size:12px;color:#a8a29e;margin-top:4px;\">{{ rate_label }}</div>{% endif %}\n              </td>\n              <td align=\"right\" style=\"padding:22px 24px;border-left:1px solid #44403c;\">\n                <div style=\"font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#a8a29e;margin-bottom:4px;\">Total (incl. tax)</div>\n                <div style=\"font-size:22px;font-weight:700;color:#ffffff;letter-spacing:-0.02em;\">{{ total_str }}</div>\n                {% if doc.deposit and doc.deposit > 0 %}<div style=\"font-size:12px;color:#a8a29e;margin-top:4px;\">Deposit: {{ frappe.utils.fmt_money(doc.deposit, currency=currency) }}</div>{% endif %}\n              </td>\n            </tr>\n          </table>\n        </td></tr>\n\n        <!-- Check-in / check-out info -->\n        <tr><td style=\"padding:24px 40px 0 40px;\">\n          <div style=\"font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#78716c;margin-bottom:10px;\">Stay Information</div>\n          <p style=\"margin:0 0 4px 0;font-size:13px;color:#44403c;line-height:1.6;\">Standard check-in from <strong>{{ ci_time }}</strong> • Standard check-out by <strong>{{ co_time }}</strong></p>\n          {% if s.late_checkout_policy %}<p style=\"margin:6px 0 0 0;font-size:12px;color:#78716c;line-height:1.5;\"><em>Late check-out:</em> {{ s.late_checkout_policy }}</p>{% endif %}\n        </td></tr>\n\n        <!-- Included services -->\n        {% if s.included_services %}\n        <tr><td style=\"padding:22px 40px 0 40px;\">\n          <div style=\"font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#78716c;margin-bottom:10px;\">What's Included</div>\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n            {% for line in s.included_services.strip().splitlines() %}{% if line.strip() %}\n            <tr><td style=\"padding:4px 0;font-size:13px;color:#44403c;line-height:1.55;\">\n              <span style=\"color:#b45309;margin-right:8px;\">✓</span>{{ line.strip() }}\n            </td></tr>\n            {% endif %}{% endfor %}\n          </table>\n        </td></tr>\n        {% endif %}\n\n        <!-- Policies -->\n        {% if s.cancellation_policy or s.airport_transfer_policy or s.booking_guarantee_policy %}\n        <tr><td style=\"padding:22px 40px 0 40px;\">\n          <div style=\"font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#78716c;margin-bottom:10px;\">Policies</div>\n          {% if s.cancellation_policy %}\n          <p style=\"margin:0 0 4px 0;font-size:13px;font-weight:600;color:#1c1917;\">Cancellation</p>\n          <p style=\"margin:0 0 12px 0;font-size:12px;color:#57534e;line-height:1.6;\">{{ s.cancellation_policy }}</p>\n          {% endif %}\n          {% if s.airport_transfer_policy %}\n          <p style=\"margin:0 0 4px 0;font-size:13px;font-weight:600;color:#1c1917;\">Airport transfer</p>\n          <p style=\"margin:0 0 12px 0;font-size:12px;color:#57534e;line-height:1.6;\">{{ s.airport_transfer_policy }}</p>\n          {% endif %}\n          {% if s.booking_guarantee_policy %}\n          <p style=\"margin:0 0 4px 0;font-size:13px;font-weight:600;color:#1c1917;\">Booking guarantee</p>\n          <p style=\"margin:0 0 12px 0;font-size:12px;color:#57534e;line-height:1.6;\">{{ s.booking_guarantee_policy }}</p>\n          {% endif %}\n        </td></tr>\n        {% endif %}\n\n        <!-- Signature -->\n        <tr><td style=\"padding:28px 40px 0 40px;\">\n          <p style=\"margin:0;font-size:14px;color:#1c1917;line-height:1.55;\">Warm regards,<br>\n            <strong style=\"color:#1c1917;\">{{ signatory }}</strong>\n            {% if sign_title %}<br><span style=\"font-size:12px;color:#78716c;\">{{ sign_title }}</span>{% endif %}\n          </p>\n        </td></tr>\n\n        <!-- Data privacy -->\n        {% if s.data_privacy_notice %}\n        <tr><td style=\"padding:28px 40px 0 40px;\">\n          <p style=\"margin:0;padding:14px 16px;background:#fafaf9;border-radius:8px;font-size:11px;color:#78716c;line-height:1.55;\">{{ s.data_privacy_notice }}</p>\n        </td></tr>\n        {% endif %}\n\n        <!-- Footer -->\n        <tr><td style=\"padding:36px 40px 32px 40px;\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"border-top:1px solid #f5f5f4;\">\n            <tr><td style=\"padding-top:20px;font-size:11px;color:#a8a29e;text-align:center;line-height:1.6;\">\n              Automated message from {{ hotel }}. Please do not reply to this email.\n            </td></tr>\n          </table>\n        </td></tr>\n\n      </table>\n\n    </td></tr>\n  </table>\n\n</body>\n</html>"
 }
]